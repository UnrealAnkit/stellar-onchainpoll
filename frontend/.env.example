# ──────────────────────────────────────────────────────────
# Stellar Live Poll — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.

# Deployed Soroban contract address on Stellar Testnet
# Get this after running: stellar contract deploy ...
NEXT_PUBLIC_CONTRACT_ID=CXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Stellar network (testnet | mainnet)
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Horizon RPC endpoint
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org

# Soroban RPC endpoint
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ── Admin / Poll Setup ──────────────────────────────────────
# The Stellar secret key of the poll admin (used to initialize poll via script)
# !! NEVER commit this to git. Keep it in .env.local only. !!
ADMIN_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
